# Qdrant vector database
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Embedding model (fastembed, запускается локально)
EMBED_MODEL=intfloat/multilingual-e5-large
EMBED_DIM=1024

#EMBED_MODEL=intfloat/multilingual-e5-base
#EMBED_DIM=768

# LLM — дефолтный провайдер (используется если нет data/llm_settings.json)
LLM_PROVIDER=openai
LLM_API_KEY=your-api-key
LLM_MODEL=gpt-4o-mini

# base_url для провайдеров (менять не нужно, только если используете прокси)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Кастомный base_url для OpenAI можно задать через API: POST /api/v1/settings/llm/provider/openai

# ── 1С интеграция ─────────────────────────────────────────────────────────────
# Базовый URL HTTP-сервиса 1С. Если не задан — все запросы к 1С отключены.
ONEC_BASE_URL=http://localhost:8081/smartmarket/hs/site-api
ONEC_USER=Администратор
ONEC_PASSWORD=

# Таймаут запросов к 1С (секунды)
ONEC_TIMEOUT=5

# ── RAG настройки ─────────────────────────────────────────────────────────────
TOP_K=6
SCORE_THRESHOLD=0.1  # RRF fusion scores (0–1), не cosine distance

# ── Уточняющие вопросы ────────────────────────────────────────────────────────
# Минимальная длина запроса (символов) при которой агент может задать уточнение.
# Короткие запросы (< MIN_QUERY_LENGTH) уточнения не вызывают.
MIN_QUERY_LENGTH=3
