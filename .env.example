# Qdrant vector database
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Embedding model (fastembed)
EMBED_MODEL=intfloat/multilingual-e5-large
EMBED_DIM=1024

#EMBED_MODEL=intfloat/multilingual-e5-base
#EMBED_DIM=768

# LLM — дефолтный провайдер (используется если нет data/llm_settings.json)
LLM_PROVIDER=openai
LLM_API_KEY=your-api-key
LLM_MODEL=gpt-4o-mini

# base_url для провайдеров (менять не нужно, только если используете прокси)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Кастомный base_url для OpenAI можно задать через API: POST /api/v1/settings/llm/provider/openai

# RAG
TOP_K=6
